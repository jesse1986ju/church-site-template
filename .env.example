# Injected by Cloudflare Pages at build time — do not commit real values.

# Supabase (shared instance — server-side ISR fetching)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Church identity (set per-site during provisioning)
CHURCH_ID=uuid-of-this-church
CHURCH_NAME=Grace Community Church

# On-demand revalidation (set a random secret, same value in dashboard)
REVALIDATE_SECRET=random-secret-string

# Cloudflare Pages deploy hook URL (generated in CF dashboard per project)
CF_DEPLOY_HOOK_URL=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/...

# Client-side event tracking (NEXT_PUBLIC_* are safe to expose — anon key only)
# These are set automatically by /api/provision during church onboarding.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_CHURCH_ID=uuid-of-this-church
